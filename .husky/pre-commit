#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Vérification du code (lint + format)..."

# Node plutôt que Bun pour éviter blocage
npx eslint src --ext .ts,.tsx
npx prettier --write .

if [ $? -ne 0 ]; then
  echo "❌ Commit annulé (erreurs détectées)"
  exit 1
fi

echo "✅ Commit accepté"
