{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.tsx",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/server.tsx",
    "hashPasswords": "bun run ./src/hashPassword.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.74.0",
    "bcrypt": "^6.0.0",
    "bunrest": "^1.3.8",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "module": "src/server.tsx",
  "peerDependencies": {
    "typescript": "^5"
  }
}
